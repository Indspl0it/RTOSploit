<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RTOSploit Engagement Report — {{ report.engagement_id }}</title>
<style>
  :root {
    --bg: #1a1a2e;
    --bg-card: #16213e;
    --bg-table: #0f3460;
    --text: #e0e0e0;
    --text-dim: #8892a0;
    --border: #2a3a5c;
    --critical: #ff4757;
    --high: #ff6b35;
    --medium: #ffc048;
    --low: #5b9cf6;
    --info: #888;
    --accent: #4ecdc4;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 2rem;
    line-height: 1.6;
  }
  h1 { color: #fff; margin-bottom: 0.5rem; }
  h2 { color: #fff; margin: 2rem 0 1rem 0; font-size: 1.3rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
  .subtitle { color: var(--text-dim); margin-bottom: 2rem; font-size: 0.95rem; }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .summary-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
  }
  .summary-card .count {
    font-size: 2rem;
    font-weight: bold;
  }
  .summary-card .label {
    font-size: 0.85rem;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .count-critical { color: var(--critical); }
  .count-high { color: var(--high); }
  .count-medium { color: var(--medium); }
  .count-low { color: var(--low); }
  .count-info { color: var(--info); }
  .count-total { color: #fff; }
  .count-accent { color: var(--accent); }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 2rem;
    background: var(--bg-card);
    border-radius: 8px;
    overflow: hidden;
  }
  th {
    background: var(--bg-table);
    padding: 0.75rem 1rem;
    text-align: left;
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  th:hover { background: #1a4a80; }
  th .sort-arrow { margin-left: 4px; font-size: 0.75rem; }
  td { padding: 0.75rem 1rem; border-top: 1px solid var(--border); }
  tr:hover td { background: rgba(255,255,255,0.03); }
  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
  }
  .badge-critical { background: var(--critical); color: #fff; }
  .badge-high { background: var(--high); color: #fff; }
  .badge-medium { background: var(--medium); color: #1a1a2e; }
  .badge-low { background: var(--low); color: #fff; }
  .badge-info { background: var(--info); color: #fff; }
  .detail-toggle {
    cursor: pointer;
    color: var(--low);
    font-size: 0.85rem;
    text-decoration: underline;
  }
  .detail-section {
    display: none;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    margin-top: 0.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.85rem;
    white-space: pre-wrap;
    word-break: break-all;
  }
  .detail-section.open { display: block; }
  .info-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
  }
  .info-panel dl { display: grid; grid-template-columns: auto 1fr; gap: 0.3rem 1.5rem; }
  .info-panel dt { color: var(--text-dim); font-weight: 600; }
  .info-panel dd { margin: 0; }
  .metadata {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }
  .metadata dt { color: var(--text-dim); display: inline; }
  .metadata dt::after { content: ': '; }
  .metadata dd { display: inline; margin-right: 2rem; }
  .periph-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .periph-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
  }
  .periph-card .name { font-weight: 600; color: var(--accent); }
  .periph-card .type { color: var(--text-dim); font-size: 0.85rem; }
  .periph-card .conf { font-size: 0.85rem; }
  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 0.8rem;
    text-align: center;
  }
</style>
</head>
<body>

<h1>RTOSploit Engagement Report</h1>
<p class="subtitle">Engagement ID: {{ report.engagement_id }}</p>

{# ---- Target Info ---- #}
<dl class="metadata">
  <dt>Firmware</dt><dd>{{ report.target_firmware }}</dd>
  {% if report.target_rtos %}<dt>RTOS</dt><dd>{{ report.target_rtos }}</dd>{% endif %}
  {% if report.target_version %}<dt>Version</dt><dd>{{ report.target_version }}</dd>{% endif %}
  <dt>Architecture</dt><dd>{{ report.target_architecture }}</dd>
  {% if report.metadata.get('mcu_family') %}<dt>MCU Family</dt><dd>{{ report.metadata['mcu_family'] }}</dd>{% endif %}
</dl>

{# ---- Severity Summary Cards ---- #}
<div class="summary-grid">
  <div class="summary-card">
    <div class="count count-total">{{ total_findings }}</div>
    <div class="label">Total</div>
  </div>
  <div class="summary-card">
    <div class="count count-critical">{{ severity_counts.critical }}</div>
    <div class="label">Critical</div>
  </div>
  <div class="summary-card">
    <div class="count count-high">{{ severity_counts.high }}</div>
    <div class="label">High</div>
  </div>
  <div class="summary-card">
    <div class="count count-medium">{{ severity_counts.medium }}</div>
    <div class="label">Medium</div>
  </div>
  <div class="summary-card">
    <div class="count count-low">{{ severity_counts.low }}</div>
    <div class="label">Low</div>
  </div>
  <div class="summary-card">
    <div class="count count-info">{{ severity_counts.info }}</div>
    <div class="label">Info</div>
  </div>
</div>

{# ---- Category Breakdown ---- #}
{% if category_counts %}
<div class="summary-grid">
  {% for cat, count in category_counts.items() %}
  <div class="summary-card">
    <div class="count count-accent">{{ count }}</div>
    <div class="label">{{ cat }}</div>
  </div>
  {% endfor %}
</div>
{% endif %}

{# ---- Fuzzing Campaign Stats ---- #}
{% if report.fuzz_stats %}
<h2>Fuzzing Campaign</h2>
<div class="info-panel">
  <dl>
    <dt>Engine</dt><dd>{{ report.fuzz_stats.engine_type }}</dd>
    <dt>Executions</dt><dd>{{ report.fuzz_stats.executions }}</dd>
    <dt>Exec/sec</dt><dd>{{ "%.1f"|format(report.fuzz_stats.exec_per_sec) }}</dd>
    <dt>Crashes</dt><dd>{{ report.fuzz_stats.crashes }} ({{ report.fuzz_stats.unique_crashes }} unique)</dd>
    <dt>Corpus Size</dt><dd>{{ report.fuzz_stats.corpus_size }}</dd>
    <dt>Duration</dt><dd>{{ "%.1f"|format(report.fuzz_stats.elapsed_seconds) }}s</dd>
  </dl>
</div>
{% endif %}

{# ---- Coverage Stats ---- #}
{% if report.coverage_stats %}
<h2>Coverage</h2>
<div class="info-panel">
  <dl>
    <dt>Type</dt><dd>{{ report.coverage_stats.coverage_type }}</dd>
    <dt>Edges Hit</dt><dd>{{ report.coverage_stats.edge_count }}</dd>
    <dt>Total Hits</dt><dd>{{ report.coverage_stats.total_hits }}</dd>
    <dt>Bitmap Size</dt><dd>{{ report.coverage_stats.bitmap_size }}</dd>
    {% if report.coverage_stats.coverage_pct > 0 %}
    <dt>Coverage</dt><dd>{{ "%.2f"|format(report.coverage_stats.coverage_pct) }}%</dd>
    {% endif %}
  </dl>
</div>
{% endif %}

{# ---- Peripheral Detection ---- #}
{% if report.peripheral_summary %}
<h2>Peripheral Detection</h2>
<div class="info-panel">
  <dl>
    <dt>MCU Family</dt><dd>{{ report.peripheral_summary.mcu_family }}</dd>
    <dt>Peripherals Detected</dt><dd>{{ report.peripheral_summary.total_detected }}</dd>
    <dt>Detection Layers</dt><dd>{{ report.peripheral_summary.layers_run | join(', ') }}</dd>
  </dl>
</div>
{% if report.peripheral_summary.peripherals %}
<div class="periph-grid">
  {% for p in report.peripheral_summary.peripherals %}
  <div class="periph-card">
    <div class="name">{{ p.name }}</div>
    <div class="type">{{ p.get('type', '') }}{% if p.get('base_address') %} @ {{ p.base_address }}{% endif %}</div>
    <div class="conf">Confidence: {{ p.get('confidence_level', 'unknown') }} ({{ "%.2f"|format(p.get('confidence', 0)) }})</div>
  </div>
  {% endfor %}
</div>
{% endif %}
{% endif %}

{# ---- Findings Table ---- #}
{% if report.findings %}
<h2>Findings</h2>
<table id="findings-table">
  <thead>
    <tr>
      <th data-col="0">ID <span class="sort-arrow"></span></th>
      <th data-col="1">Severity <span class="sort-arrow"></span></th>
      <th data-col="2">Category <span class="sort-arrow"></span></th>
      <th data-col="3">Title <span class="sort-arrow"></span></th>
      <th data-col="4">Details</th>
    </tr>
  </thead>
  <tbody>
    {% for finding in report.findings %}
    <tr>
      <td>{{ finding.id[:12] }}</td>
      <td><span class="badge badge-{{ finding.severity }}">{{ finding.severity }}</span></td>
      <td>{{ finding.category }}</td>
      <td>{{ finding.title }}</td>
      <td>
        <span class="detail-toggle" onclick="toggleDetail('detail-{{ loop.index }}')">show</span>
        <div class="detail-section" id="detail-{{ loop.index }}">
{{ finding.description }}
{% if finding.stop_reason %}
Stop Reason: {{ finding.stop_reason }}{% endif %}
{% if finding.engine_type %}
Engine: {{ finding.engine_type }}{% endif %}
{% if finding.blocks_executed %}
Blocks Executed: {{ finding.blocks_executed }}{% endif %}
{% if finding.registers %}
Registers:
{% for reg, val in finding.registers.items() %}  {{ reg }}: 0x{{ '%08x' % val }}
{% endfor %}{% endif %}
{% if finding.stack_trace %}
Stack Trace:
{% for addr in finding.stack_trace %}  0x{{ '%08x' % addr }}
{% endfor %}{% endif %}
{% if finding.pip_stats %}
PIP Stats:
{% for k, v in finding.pip_stats.items() %}  {{ k }}: {{ v }}
{% endfor %}{% endif %}
{% if finding.cve %}CVE: {{ finding.cve }}{% endif %}
{% if finding.exploit_module %}Module: {{ finding.exploit_module }}{% endif %}
{% if finding.exploitability %}Exploitability: {{ finding.exploitability }}{% endif %}
{% if finding.reproducer_path %}Reproducer: {{ finding.reproducer_path }}{% endif %}
        </div>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p style="text-align:center; color:var(--text-dim); padding:2rem;">No findings recorded.</p>
{% endif %}

<footer>
  Generated by RTOSploit | Timestamp: {{ report.timestamp }}
</footer>

<script>
function toggleDetail(id) {
  var el = document.getElementById(id);
  el.classList.toggle('open');
  var toggle = el.previousElementSibling;
  toggle.textContent = el.classList.contains('open') ? 'hide' : 'show';
}

(function() {
  var table = document.getElementById('findings-table');
  if (!table) return;
  var headers = table.querySelectorAll('th[data-col]');
  var sortState = {};

  headers.forEach(function(th) {
    th.addEventListener('click', function() {
      var col = parseInt(th.getAttribute('data-col'));
      var tbody = table.querySelector('tbody');
      var rows = Array.from(tbody.querySelectorAll('tr'));
      var asc = sortState[col] !== 'asc';
      sortState[col] = asc ? 'asc' : 'desc';

      var severityOrder = {critical: 0, high: 1, medium: 2, low: 3, info: 4};

      rows.sort(function(a, b) {
        var aText = a.children[col].textContent.trim().toLowerCase();
        var bText = b.children[col].textContent.trim().toLowerCase();
        if (col === 1) {
          var aVal = severityOrder[aText] !== undefined ? severityOrder[aText] : 5;
          var bVal = severityOrder[bText] !== undefined ? severityOrder[bText] : 5;
          return asc ? aVal - bVal : bVal - aVal;
        }
        return asc ? aText.localeCompare(bText) : bText.localeCompare(aText);
      });

      rows.forEach(function(row) { tbody.appendChild(row); });

      headers.forEach(function(h) {
        h.querySelector('.sort-arrow').textContent = '';
      });
      th.querySelector('.sort-arrow').textContent = asc ? '\u25B2' : '\u25BC';
    });
  });
})();
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RTOSploit Coverage Report</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
    background: #1a1a2e;
    color: #e0e0e0;
    display: flex;
    flex-direction: column;
    height: 100vh;
  }

  /* Header / Stats bar */
  .header {
    background: #16213e;
    padding: 16px 24px;
    border-bottom: 2px solid #0f3460;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .header h1 {
    font-size: 18px;
    color: #00d4ff;
    white-space: nowrap;
  }
  .stat-box {
    background: #0f3460;
    padding: 8px 16px;
    border-radius: 6px;
    text-align: center;
    min-width: 120px;
  }
  .stat-box .label { font-size: 11px; color: #8a8a9a; text-transform: uppercase; }
  .stat-box .value { font-size: 20px; font-weight: bold; color: #00d4ff; }

  /* Scroll-to-address bar */
  .search-bar {
    background: #16213e;
    padding: 8px 24px;
    border-bottom: 1px solid #0f3460;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .search-bar label { color: #8a8a9a; font-size: 13px; }
  .search-bar input {
    background: #0f3460;
    border: 1px solid #1a4080;
    color: #e0e0e0;
    padding: 4px 10px;
    border-radius: 4px;
    font-family: inherit;
    font-size: 13px;
    width: 180px;
  }
  .search-bar button {
    background: #0f3460;
    border: 1px solid #1a4080;
    color: #00d4ff;
    padding: 4px 12px;
    border-radius: 4px;
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
  }
  .search-bar button:hover { background: #1a4080; }

  /* Layout: sidebar + main */
  .content {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* Function sidebar */
  .sidebar {
    width: 240px;
    min-width: 200px;
    background: #16213e;
    border-right: 1px solid #0f3460;
    overflow-y: auto;
    padding: 12px 0;
  }
  .sidebar h2 {
    font-size: 13px;
    color: #8a8a9a;
    text-transform: uppercase;
    padding: 0 16px 8px;
    border-bottom: 1px solid #0f3460;
    margin-bottom: 8px;
  }
  .func-entry {
    padding: 4px 16px;
    font-size: 12px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
  }
  .func-entry:hover { background: #0f3460; }
  .func-entry .name { color: #e0e0e0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .func-entry .pct { color: #00d4ff; min-width: 45px; text-align: right; }

  /* Main disassembly view */
  .disasm {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }
  .disasm table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .disasm th {
    position: sticky;
    top: 0;
    background: #16213e;
    color: #8a8a9a;
    text-align: left;
    padding: 6px 10px;
    border-bottom: 2px solid #0f3460;
    font-size: 11px;
    text-transform: uppercase;
  }
  .disasm td {
    padding: 2px 10px;
    white-space: nowrap;
    border-bottom: 1px solid #1a1a2e;
  }
  .disasm tr:hover { background: rgba(255,255,255,0.04); }

  /* Hit count bar */
  .hit-bar {
    display: inline-block;
    height: 10px;
    border-radius: 2px;
    vertical-align: middle;
    margin-right: 6px;
  }

  /* Color legend */
  .legend {
    background: #16213e;
    padding: 8px 24px;
    border-top: 1px solid #0f3460;
    display: flex;
    gap: 20px;
    font-size: 12px;
    color: #8a8a9a;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .legend-swatch {
    width: 16px;
    height: 10px;
    border-radius: 2px;
    display: inline-block;
  }
</style>
</head>
<body>

<!-- Stats header -->
<div class="header">
  <h1>RTOSploit Coverage Report</h1>
  <div class="stat-box">
    <div class="label">Total Instructions</div>
    <div class="value">{{ stats.total_instructions }}</div>
  </div>
  <div class="stat-box">
    <div class="label">Covered</div>
    <div class="value">{{ stats.covered_instructions }}</div>
  </div>
  <div class="stat-box">
    <div class="label">Coverage</div>
    <div class="value">{{ "%.1f"|format(stats.coverage_percent) }}%</div>
  </div>
  <div class="stat-box">
    <div class="label">Edges</div>
    <div class="value">{{ stats.total_edges }}</div>
  </div>
</div>

<!-- Scroll-to-address -->
<div class="search-bar">
  <label for="addr-input">Go to address:</label>
  <input type="text" id="addr-input" placeholder="0x08000000">
  <button onclick="scrollToAddress()">Go</button>
</div>

<div class="content">
  <!-- Function sidebar -->
  <div class="sidebar">
    <h2>Hot Spots</h2>
    {% for addr, count in hot_spots %}
    <div class="func-entry" onclick="scrollToRow('{{ '0x%08x'|format(addr) }}')">
      <span class="name">{{ '0x%08x'|format(addr) }}</span>
      <span class="pct">{{ count }} hits</span>
    </div>
    {% endfor %}
    {% if not hot_spots %}
    <div class="func-entry"><span class="name" style="color:#555;">No hot spots</span></div>
    {% endif %}
  </div>

  <!-- Main disassembly -->
  <div class="disasm">
    <table>
      <thead>
        <tr>
          <th>Address</th>
          <th>Mnemonic</th>
          <th>Operands</th>
          <th>Hits</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for insn in instructions %}
        <tr id="addr-{{ insn.address }}" style="
          {%- if insn.hits == 0 -%}
            color: #555;
          {%- elif insn.ratio > 0.8 -%}
            color: #ffffaa; background: rgba(255,255,100,0.08);
          {%- elif insn.ratio > 0.4 -%}
            color: #66ff66;
          {%- else -%}
            color: #338833;
          {%- endif -%}
        ">
          <td>{{ insn.address }}</td>
          <td>{{ insn.mnemonic }}</td>
          <td>{{ insn.op_str }}</td>
          <td>{{ insn.hits }}</td>
          <td>
            {%- if insn.hits > 0 -%}
            <span class="hit-bar" style="
              width: {{ (insn.ratio * 80)|int }}px;
              background: {% if insn.ratio > 0.8 %}#ffffaa{% elif insn.ratio > 0.4 %}#66ff66{% else %}#338833{% endif %};
            "></span>
            {%- endif -%}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<!-- Legend -->
<div class="legend">
  <div class="legend-item">
    <span class="legend-swatch" style="background:#555;"></span> Uncovered
  </div>
  <div class="legend-item">
    <span class="legend-swatch" style="background:#338833;"></span> Low hits
  </div>
  <div class="legend-item">
    <span class="legend-swatch" style="background:#66ff66;"></span> Medium hits
  </div>
  <div class="legend-item">
    <span class="legend-swatch" style="background:#ffffaa;"></span> Hot (high hits)
  </div>
</div>

<script>
function scrollToAddress() {
  var addr = document.getElementById('addr-input').value.trim().toLowerCase();
  if (!addr.startsWith('0x')) addr = '0x' + addr;
  // Pad to 10 chars (0x + 8 hex digits)
  var hex = addr.slice(2).padStart(8, '0');
  scrollToRow('0x' + hex);
}

function scrollToRow(addr) {
  var el = document.getElementById('addr-' + addr);
  if (el) {
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    el.style.outline = '2px solid #00d4ff';
    setTimeout(function() { el.style.outline = ''; }, 2000);
  }
}
</script>
</body>
</html>
